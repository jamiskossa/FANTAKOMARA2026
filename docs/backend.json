
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Profil utilisateur avec rôle et informations de santé.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "collaborator", "admin"] },
        "phone": { "type": "string" },
        "carteVitale": { "type": "string", "description": "Numéro de carte vitale chiffré" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Produit du catalogue avec gestion de stock.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "isMedication": { "type": "boolean" },
        "imageUrl": { "type": "string" }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "description": "Réservation de produits ou préparation d'ordonnance.",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "prepared", "ready", "delivered", "canceled"] },
        "items": { "type": "array", "items": { "type": "object" } },
        "totalPrice": { "type": "number" },
        "prescriptionScan": { "type": "string" },
        "deliveryOption": { "type": "string", "enum": ["click-and-collect", "delivery"] },
        "assignedCollaborator": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "recipientId": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/reservations/{reservationId}", "definition": { "entityName": "Reservation" } },
      { "path": "/notifications/{notifId}", "definition": { "entityName": "Notification" } }
    ]
  }
}
