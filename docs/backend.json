
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Profil utilisateur avec rôle et informations de santé.",
      "properties": {
        "id": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "collaborator", "admin"] },
        "phone": { "type": "string" },
        "carteVitale": { "type": "string" },
        "verified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "role"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Produit avec gestion de stock détaillée.",
      "properties": {
        "id": { "type": "string" },
        "code": { "type": "string", "description": "Code barre ou SKU" },
        "name": { "type": "string" },
        "brand": { "type": "string" },
        "category": { "type": "string" },
        "price": { "type": "number" },
        "stockInitial": { "type": "number" },
        "stockFinal": { "type": "number" },
        "ecart": { "type": "number" },
        "expiryDate": { "type": "string", "format": "date" },
        "isMedication": { "type": "boolean" }
      }
    },
    "Supplier": {
      "title": "Supplier",
      "type": "object",
      "description": "Fournisseur ou partenaire de l'officine.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["fournisseur", "pharmacie", "partenaire", "urgence"] },
        "contactName": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "notes": { "type": "string" }
      }
    },
    "Reservation": {
      "title": "Reservation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string" },
        "totalPrice": { "type": "number" },
        "createdAt": { "type": "string" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "structure": [
      { "path": "/userProfiles/{userId}", "definition": { "entityName": "UserProfile" } },
      { "path": "/products/{productId}", "definition": { "entityName": "Product" } },
      { "path": "/reservations/{reservationId}", "definition": { "entityName": "Reservation" } },
      { "path": "/suppliers/{supplierId}", "definition": { "entityName": "Supplier" } }
    ]
  }
}
