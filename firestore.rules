
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    
    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role in ["admin", "collaborator"];
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations & Support
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && (isStaff() || (resource.data.clientId == request.auth.uid && resource.data.status == "pending"));
      allow delete: if isAdmin();
    }

    match /supportMessages/{msgId} {
      allow read: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isStaff();
    }

    // Fournisseurs
    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Chat Interne Staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    
    // Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isStaff();
    }
  }
}
