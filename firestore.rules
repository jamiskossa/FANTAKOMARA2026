rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────
    // Fonctions utilitaires sécurisées
    // ────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function userProfileExists() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated()
        && userProfileExists()
        && getUserData().role in ["admin", "collaborator", "collaborateur"];
    }

    function isAdmin() {
      return isAuthenticated()
        && userProfileExists()
        && getUserData().role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isResourceOwner() {
      return resource != null
        && resource.data.clientId == request.auth.uid;
    }

    // ────────────────────────────────────────────────
    // RÈGLES PAR COLLECTION
    // ────────────────────────────────────────────────

    // 🔐 Profils utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();
    }

    // 🛍 Produits (catalogue public)
    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    // 📦 Réservations
    match /reservations/{reservationId} {

      // Création sécurisée
      allow create: if isAuthenticated()
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == "pending"
        && request.resource.data.keys().hasAll(["clientId", "status", "createdAt"]);

      // Lecture document unique
      allow get: if isAuthenticated()
        && (isStaff() || isResourceOwner());

      // Liste sécurisée (anti-abus)
      allow list: if isStaff()
        || (isAuthenticated()
            && request.query.limit != null
            && request.query.limit <= 50);

      // Update limité
      allow update: if isStaff()
        || (isAuthenticated()
            && isResourceOwner()
            && resource.data.status == "pending"
            && request.resource.data
                 .diff(resource.data)
                 .affectedKeys()
                 .hasOnly(["status", "notes", "updatedAt"]));

      allow delete: if isAdmin();
    }

    // 💬 Support client ↔ staff
    match /supportMessages/{msgId} {

      allow create: if isAuthenticated()
        && request.resource.data.clientId == request.auth.uid;

      allow get: if isAuthenticated()
        && (isStaff() || resource.data.clientId == request.auth.uid);

      allow list: if isStaff()
        || (isAuthenticated()
            && request.query.limit != null
            && request.query.limit <= 50);

      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // 👥 Chat interne staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // 📩 Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ✉️ Mail (extension Firebase Email)
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // 📧 Newsletter
    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // ⭐ Avis pharmacie
    match /pharmacyReviews/{id} {
      allow create: if isAuthenticated();
      allow read: if true;
      allow update, delete: if isAdmin();
    }

    // 🧑‍💼 Sessions collaborateurs
    match /collaboratorSessions/{id} {
      allow create, read, update, delete: if isAdmin();
    }

    // 🚫 Catch-all (sécurité maximale)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}