
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de rôles
    function isAuthenticated() { return request.auth != null; }
    function getUserRole() { return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role; }
    function isAdmin() { return isAuthenticated() && getUserRole() == "admin"; }
    function isCollaborator() { return isAuthenticated() && getUserRole() == "collaborator"; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isCollaborator() || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isOwner(userId) || isAdmin();
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isCollaborator() || isAdmin();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow read: if isOwner(resource.data.clientId) || isCollaborator() || isAdmin();
      allow create: if isAuthenticated();
      allow update: if isCollaborator() || isAdmin() || (isOwner(resource.data.clientId) && resource.data.status == "pending");
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isCollaborator() || isAdmin();
    }
  }
}
