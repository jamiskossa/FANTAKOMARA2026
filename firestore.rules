
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de base
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Récupération sécurisée du rôle
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isAdmin() { return hasRole("admin"); }
    function isCollaborator() { return hasRole("collaborator"); }
    function isStaff() { return isAdmin() || isCollaborator(); }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isStaff();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow list: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid && resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    // Support / Chat - Correction ici
    match /supportMessages/{msgId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow list: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && isStaff();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isStaff();
    }

    // Messages de contact
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isStaff();
    }
    
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
