
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de base
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Récupération sécurisée du rôle
    function getRole() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
             getRole() == role;
    }

    function isAdmin() { return hasRole("admin"); }
    function isCollaborator() { return hasRole("collaborator"); }
    function isClient() { return hasRole("client"); }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isCollaborator() || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isCollaborator() || isAdmin();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow get: if isAuthenticated() && (isOwner(resource.data.clientId) || isCollaborator() || isAdmin());
      allow list: if isCollaborator() || isAdmin() || (isAuthenticated() && resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isCollaborator() || isAdmin() || (isOwner(resource.data.clientId) && resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    // Support / Chat
    match /supportMessages/{msgId} {
      allow read: if isOwner(resource.data.clientId) || isCollaborator() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isCollaborator() || isAdmin();
    }

    // Messages de contact
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isCollaborator() || isAdmin();
    }
    
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
