rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════
    // FONCTIONS DE BASE
    // ═══════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    // Récupère le rôle de l'utilisateur. 
    function getUserRole() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) 
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role 
        : "none";
    }

    function isStaff() {
      return isAuthenticated() && getUserRole() in ["admin", "collaborator", "collaborateur"];
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ═══════════════════════════════════════
    // USER PROFILES
    // ═══════════════════════════════════════

    match /userProfiles/{userId} {
      // Priorité à l'owner pour éviter l'appel isStaff() (et donc le get()) pour les clients
      allow read: if isOwner(userId) || isStaff();

      allow create: if isAuthenticated() && (
        isAdmin() || (isOwner(userId) && request.resource.data.role == "client")
      );

      allow update: if isAuthenticated() && (
        isAdmin() || (isOwner(userId) && !("role" in request.resource.data.diff(resource.data).affectedKeys()))
      );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // RESERVATIONS
    // ═══════════════════════════════════════

    match /reservations/{reservationId} {
      allow create: if isAuthenticated() && (
        request.resource.data.get('clientId', '') == request.auth.uid || isStaff()
      );

      // On sépare get et list pour être plus précis
      // Pour list: l'ownership doit être checké en premier pour le short-circuit
      allow read: if isAuthenticated() && (
        resource.data.get('clientId', '') == request.auth.uid || isStaff()
      );

      allow update: if isAuthenticated() && (
        (resource.data.get('clientId', '') == request.auth.uid && resource.data.get('status', '') == "pending") || isStaff()
      );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // PRODUITS
    // ═══════════════════════════════════════

    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    // ═══════════════════════════════════════
    // CHAT SUPPORT & MESSAGES
    // ═══════════════════════════════════════

    match /supportMessages/{id} {
      allow create: if isAuthenticated() && (
        request.resource.data.get('clientId', '') == request.auth.uid || isStaff()
      );

      allow read: if isAuthenticated() && (
        resource.data.get('clientId', '') == request.auth.uid || isStaff()
      );

      allow update, delete: if isAdmin();
    }

    match /staffMessages/{id} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    match /contactMessages/{id} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // SESSIONS & LOGS
    // ═══════════════════════════════════════

    match /collaboratorSessions/{sessionId} {
      allow create: if isStaff() && request.resource.data.collaboratorId == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.collaboratorId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // AUTRES COLLECTIONS
    // ═══════════════════════════════════════

    match /newsletter/{id} {
      allow create: if true;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }

    match /pharmacyReviews/{id} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // Sécurité par défaut
    match /{document=**} {
      allow read, write: if false;
    }
  }
}