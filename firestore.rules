rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════
    // FONCTIONS
    // ═══════════════════════════════════════

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserRole() {
      return isAuthenticated() && exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid))
        ? get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role
        : null;
    }

    function isAdmin() {
      return getUserRole() == "admin";
    }

    function isCollaborator() {
      return getUserRole() == "collaborator" || getUserRole() == "collaborateur";
    }

    function isStaff() {
      return getUserRole() == "admin" || getUserRole() == "collaborator" || getUserRole() == "collaborateur";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // ═══════════════════════════════════════
    // USER PROFILES
    // ═══════════════════════════════════════

    match /userProfiles/{userId} {

      // Admin voit tout
      // Collaborateur peut lire profils (pour chat clients)
      // Client voit uniquement son profil
      allow read: if isOwner(userId) || isStaff();

      // Création :
      // Admin peut créer admin/collaborator/client
      // Client peut créer uniquement son propre profil avec role = client
      allow create: if isAdmin()
        || (
          isOwner(userId)
          && request.resource.data.role == "client"
        );

      // Update :
      // Admin peut modifier tout
      // Client peut modifier son profil sauf role
      allow update: if isAdmin()
        || (
          isOwner(userId)
          && !("role" in request.resource.data.diff(resource.data).affectedKeys())
        );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // RESERVATIONS
    // ═══════════════════════════════════════

    match /reservations/{reservationId} {

      // Client crée sa réservation
      allow create: if isAuthenticated()
        && request.resource.data.clientId == request.auth.uid;

      // Lecture document unique
      allow get: if isStaff()
        || (isAuthenticated() && resource.data.clientId == request.auth.uid);

      // LIST (IMPORTANT pour ton dashboard)
      // Pour le client : on force le filtrage par clientId dans la règle
      allow list: if isStaff()
        || (
          isAuthenticated()
          && resource.data.clientId == request.auth.uid
        );

      // Update
      allow update: if isStaff()
        || (
          isAuthenticated()
          && resource.data.clientId == request.auth.uid
          && resource.data.status == "pending"
        );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // PRODUITS
    // ═══════════════════════════════════════

    match /products/{id} {
      allow read: if true;
      allow create, update, delete: if isStaff();
    }

    // ═══════════════════════════════════════
    // CHAT INTERNE STAFF
    // ═══════════════════════════════════════

    match /staffMessages/{id} {
      allow read, create: if isStaff();
      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // SUPPORT CLIENT
    // ═══════════════════════════════════════

    match /supportMessages/{id} {

      allow create: if isAuthenticated();

      allow get: if isStaff()
        || (isAuthenticated() && resource.data.clientId == request.auth.uid);

      allow list: if isStaff()
        || (
          isAuthenticated()
          && resource.data.clientId == request.auth.uid
        );

      allow update, delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // CONTACT MESSAGES
    // ═══════════════════════════════════════

    match /contactMessages/{id} {
      allow create: if true;
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // COLLABORATOR SESSIONS
    // ═══════════════════════════════════════

    match /collaboratorSessions/{sessionId} {

      allow create: if isStaff()
        && request.resource.data.collaboratorId == request.auth.uid;

      allow read: if isAdmin()
        || (
          isStaff()
          && resource.data.collaboratorId == request.auth.uid
        );

      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // NEWSLETTER
    // ═══════════════════════════════════════
    match /newsletter/{id} {
      allow create: if true;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // REVIEWS
    // ═══════════════════════════════════════
    match /pharmacyReviews/{id} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.clientId) || isAdmin();
      allow delete: if isAdmin();
    }

    // ═══════════════════════════════════════
    // BLOCK EVERYTHING ELSE
    // ═══════════════════════════════════════

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
