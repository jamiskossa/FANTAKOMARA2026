
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de base
    function isAuthenticated() { return request.auth != null; }
    function isOwner(userId) { return isAuthenticated() && request.auth.uid == userId; }

    // Récupération sécurisée du rôle (évite les erreurs si le doc n'existe pas)
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    function isAdmin() { return hasRole("admin"); }
    function isCollaborator() { return hasRole("collaborator"); }

    // Profils Utilisateurs : Un utilisateur peut toujours créer/modifier son propre profil
    match /userProfiles/{userId} {
      allow read: if isOwner(userId) || isCollaborator() || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isCollaborator() || isAdmin();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow read: if isAuthenticated() && (isOwner(resource.data.clientId) || isCollaborator() || isAdmin());
      allow create: if isAuthenticated();
      allow update: if isCollaborator() || isAdmin() || (isOwner(resource.data.clientId) && resource.data.status == "pending");
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isCollaborator() || isAdmin();
    }

    // Messages de contact (utilisés par l'extension Trigger Email)
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isCollaborator() || isAdmin();
    }
    
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
