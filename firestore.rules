
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de base sécurisées et optimisées
    function isAuthenticated() { return request.auth != null; }
    
    function getUserData() {
      // Utilisation d'un chemin direct pour plus d'efficacité
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    function isStaff() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role in ["admin", "collaborator"];
    }

    function isAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == "admin";
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations - Séparation des règles list pour éviter les erreurs de validation
    match /reservations/{reservationId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      
      // Le staff peut tout lister
      allow list: if isStaff();
      // Le client ne peut lister que ses propres réservations (requête filtrée obligatoire)
      allow list: if isAuthenticated() && resource.data.clientId == request.auth.uid;
      
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && (isStaff() || (resource.data.clientId == request.auth.uid && resource.data.status == "pending"));
      allow delete: if isAdmin();
    }

    // Fournisseurs
    match /suppliers/{supplierId} {
      allow read: if isStaff();
      allow write: if isAdmin();
    }

    // Chat Interne Staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Support Clients
    match /supportMessages/{msgId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      
      // Split list rules
      allow list: if isStaff();
      allow list: if isAuthenticated() && resource.data.clientId == request.auth.uid;
      
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isStaff();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
    
    // Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isStaff();
    }
  }
}
