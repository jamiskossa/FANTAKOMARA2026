rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin" || 
              get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "collaborator" ||
              get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "collaborateur");
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data.role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (isStaff() || (resource != null && resource.data.clientId == request.auth.uid));
      allow update: if isStaff() || (isAuthenticated() && resource != null && resource.data.clientId == request.auth.uid && resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    // Support Clients (Chat)
    match /supportMessages/{msgId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow update: if isStaff();
    }

    // Chat Interne Staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    // Newsletter
    match /newsletter/{id} {
      allow create: if true;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }

    // Avis Pharmacie
    match /pharmacyReviews/{id} {
      allow create: if isAuthenticated();
      allow read: if true;
      allow delete: if isAdmin();
    }

    // Sessions Collaborateurs
    match /collaboratorSessions/{id} {
      allow create: if isStaff();
      allow read: if isAdmin();
      allow update, delete: if isAdmin();
    }
  }
}
