
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             (getUserData().role == "admin" || getUserData().role == "collaborator");
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) &&
             getUserData().role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow create: if isAuthenticated();
      // On sépare explicitement get et list pour plus de robustesse
      allow get: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow list: if isAuthenticated() && (isStaff() || (request.query.limit <= 100 && resource.data.clientId == request.auth.uid));
      allow update: if isAuthenticated() && (isStaff() || (resource.data.clientId == request.auth.uid && resource.data.status == "pending"));
      allow delete: if isAdmin();
    }

    // Support Clients
    match /supportMessages/{msgId} {
      allow create: if isAuthenticated();
      allow get: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow list: if isAuthenticated() && (isStaff() || (resource.data.clientId == request.auth.uid));
      allow update: if isStaff();
    }

    // Chat Interne Staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isStaff();
      allow delete: if isAdmin();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
