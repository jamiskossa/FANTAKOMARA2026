
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Fonctions de base
    function isAuthenticated() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }
    
    function isStaff() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
             getUserData().role in ["admin", "collaborator"];
    }

    function isAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)) && 
             getUserData().role == "admin";
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (request.auth.uid == userId || isStaff());
      allow write: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isAuthenticated() && isStaff();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow list: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && (isStaff() || (resource.data.clientId == request.auth.uid && resource.data.status == "pending"));
      allow delete: if isAuthenticated() && isAdmin();
    }

    // Annuaire / Fournisseurs
    match /suppliers/{supplierId} {
      allow read: if isAuthenticated() && isStaff();
      allow write: if isAuthenticated() && isAdmin();
    }

    // Support / Chat
    match /supportMessages/{msgId} {
      allow get: if isAuthenticated() && (resource.data.clientId == request.auth.uid || isStaff());
      allow list: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      allow update: if isAuthenticated() && isStaff();
    }

    // Notifications
    match /notifications/{notifId} {
      allow read: if isAuthenticated() && resource.data.recipientId == request.auth.uid;
      allow create: if isAuthenticated() && isStaff();
    }

    // Messages de contact
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read: if isAuthenticated() && isStaff();
    }
    
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAuthenticated() && isAdmin();
    }
  }
}
