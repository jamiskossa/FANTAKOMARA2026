rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ────────────────────────────────────────────────
    // Fonctions utilitaires (améliorées)
    // ────────────────────────────────────────────────

    function isAuthenticated() {
      return request.auth != null;
    }

    function userProfileExists() {
      return exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() 
        && userProfileExists()
        && getUserData().role in ["admin", "collaborator", "collaborateur"];
    }

    function isAdmin() {
      return isAuthenticated() 
        && userProfileExists()
        && getUserData().role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    function isResourceOwner() {
      return resource != null 
        && resource.data.clientId == request.auth.uid;
    }

    // ────────────────────────────────────────────────
    // Règles par collection
    // ────────────────────────────────────────────────

    // Profils Utilisateurs – très sensible
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());
      allow delete: if isAdmin();  // rare, mais possible pour admin
    }

    // Produits (catalogue) – lecture publique, édition staff seulement
    match /products/{productId} {
      allow read: if true;               // catalogue visible par tous
      allow create, update, delete: if isStaff();
    }

    // Réservations – la collection qui posait problème
    match /reservations/{reservationId} {
      // CREATE : tout utilisateur auth peut créer sa propre résa
      allow create: if isAuthenticated()
                    && request.resource.data.clientId == request.auth.uid
                    && "status" in request.resource.data
                    && request.resource.data.status == "pending";

      // GET (lecture d'un document spécifique)
      allow get: if isAuthenticated() 
                 && (isStaff() || isResourceOwner());

      // LIST (récupérer plusieurs documents)
      // → Staff : tout
      // → Client : seulement ses propres (via filtre + limite stricte)
      allow list: if isStaff()
                 || (isAuthenticated() 
                     && request.query.limit <= 50          // anti-abus (ajustable)
                     && request.query.limit != null);      // force la présence d'un limit

      // UPDATE : staff ou propriétaire si toujours "pending"
      allow update: if isStaff()
                    || (isAuthenticated() 
                        && isResourceOwner()
                        && resource.data.status == "pending"
                        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "notes", "updatedAt"]));  // limite les champs modifiables

      // DELETE : seulement admin (ou staff si tu veux, mais prudence)
      allow delete: if isAdmin();
    }

    // Support Messages (chat client ↔ staff)
    match /supportMessages/{msgId} {
      allow create: if isAuthenticated()
                    && request.resource.data.clientId == request.auth.uid;

      allow get: if isAuthenticated() 
                 && (isStaff() || (resource != null && resource.data.clientId == request.auth.uid));

      allow list: if isStaff()
                 || (isAuthenticated() 
                     && request.query.limit <= 50
                     && request.query.limit != null);

      allow update: if isStaff();  // seul staff peut répondre/marquer lu/etc.
      allow delete: if isAdmin();
    }

    // Chat interne staff – strict
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Messages de contact (depuis le site, non-auth)
    match /contactMessages/{msgId} {
      allow create: if true;           // formulaire public
      allow read, update: if isStaff();
      allow delete: if isAdmin();
    }

    // Mail (pour extension Trigger Email)
    match /mail/{mailId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Newsletter inscriptions
    match /newsletter/{id} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    // Avis pharmacie
    match /pharmacyReviews/{id} {
      allow create: if isAuthenticated();
      allow read: if true;             // visible publiquement
      allow update: if isAdmin();      // modération
      allow delete: if isAdmin();
    }

    // Sessions collaborateurs
    match /collaboratorSessions/{id} {
      allow create, read, update, delete: if isAdmin();  // ou isStaff() si besoin
    }

    // Catch-all : DENY par défaut (sécurité)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
