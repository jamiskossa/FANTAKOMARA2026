
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() { return request.auth != null; }
    
    function getUserData() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;
    }

    function isStaff() {
      return isAuthenticated() && 
             getUserData().role in ["admin", "collaborator"];
    }

    function isAdmin() {
      return isAuthenticated() && getUserData().role == "admin";
    }

    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Profils Utilisateurs
    match /userProfiles/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());
      allow write: if isAuthenticated() && (isOwner(userId) || isAdmin());
    }

    // Catalogue Produits
    match /products/{productId} {
      allow read: if true;
      allow write: if isStaff();
    }

    // Réservations
    match /reservations/{reservationId} {
      allow create: if isAuthenticated();
      // Lecture autorisée pour le staff (tout) ou le client (ses propres docs)
      allow read: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow update: if isStaff() || (isAuthenticated() && resource.data.clientId == request.auth.uid && resource.data.status == "pending");
      allow delete: if isAdmin();
    }

    // Support Clients (Chat)
    match /supportMessages/{msgId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);
      allow update: if isStaff();
    }

    // Avis Pharmacie
    match /pharmacyReviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow delete: if isAdmin();
    }

    // Sessions Collaborateurs
    match /collaboratorSessions/{sessionId} {
      allow read, write: if isStaff();
    }

    // Newsletter
    match /newsletter/{id} {
      allow create: if true;
      allow read: if isStaff();
    }

    // Chat Interne Staff
    match /staffMessages/{msgId} {
      allow read, write: if isStaff();
    }

    // Messages de contact (public)
    match /contactMessages/{msgId} {
      allow create: if true;
      allow read: if isStaff();
      allow update: if isStaff();
      allow delete: if isAdmin();
    }

    // Mail (Trigger Email Extension)
    match /mail/{mailId} {
      allow create: if true;
      allow read: if isAdmin();
    }
  }
}
