[debug] [2026-02-25T15:51:36.151Z] >>> [apiv2][body] PUT http://127.0.0.1:8080/emulator/v1/projects/studio-98021600-d9d31:securityRules {"ignore_errors":true,"rules":{"files":[{"name":"security.rules","content":"rules_version = '2';\r\n\r\nservice cloud.firestore {\r\n  match /databases/{database}/documents {\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Fonctions utilitaires sécurisées\r\n    // ────────────────────────────────────────────────\r\n    function isAuthenticated() {\r\n      return request.auth != null;\r\n    }\r\n\r\n    function userProfileExists() {\r\n      return isAuthenticated() &&\r\n        exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid));\r\n    }\r\n\r\n    function getUserData() {\r\n      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid)).data;\r\n    }\r\n\r\n    function isStaff() {\r\n      return isAuthenticated()\r\n        && userProfileExists()\r\n        && getUserData().role in [\"admin\", \"collaborator\", \"collaborateur\"];\r\n    }\r\n\r\n    function isAdmin() {\r\n      return isAuthenticated()\r\n        && userProfileExists()\r\n        && getUserData().role == \"admin\";\r\n    }\r\n\r\n    function isOwner(uid) {\r\n      return isAuthenticated() && request.auth.uid == uid;\r\n    }\r\n\r\n    function isResourceOwner() {\r\n      return resource != null\r\n        && resource.data.clientId == request.auth.uid;\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Profils utilisateurs\r\n    // ────────────────────────────────────────────────\r\n    match /userProfiles/{userId} {\r\n      allow read: if isAuthenticated() && (isOwner(userId) || isStaff());\r\n      allow create: if isAuthenticated() && isOwner(userId);\r\n      allow update: if isAuthenticated() && (isOwner(userId) || isAdmin());\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Produits (catalogue public)\r\n    // ────────────────────────────────────────────────\r\n    match /products/{productId} {\r\n      allow read: if true;\r\n      allow create, update, delete: if isStaff();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Réservations\r\n    // ────────────────────────────────────────────────\r\n    match /reservations/{reservationId} {\r\n      allow create: if isAuthenticated()\r\n        && request.resource.data.clientId == request.auth.uid\r\n        && request.resource.data.status == \"pending\"\r\n        && request.resource.data.keys().hasOnly([\r\n          \"clientId\",\r\n          \"status\",\r\n          \"createdAt\",\r\n          \"totalPrice\",\r\n          \"type\",\r\n          \"notes\"\r\n        ]);\r\n\r\n      allow get: if isAuthenticated() && (isStaff() || isResourceOwner());\r\n\r\n      allow list: if isStaff()\r\n        || (isAuthenticated()\r\n            && request.query.limit != null\r\n            && request.query.limit <= 50);\r\n\r\n      allow update: if isStaff()\r\n        || (isAuthenticated()\r\n            && isResourceOwner()\r\n            && resource.data.status == \"pending\"\r\n            && request.resource.data\r\n                 .diff(resource.data)\r\n                 .affectedKeys()\r\n                 .hasOnly([\"status\", \"notes\", \"updatedAt\"]));\r\n\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Support client\r\n    // ────────────────────────────────────────────────\r\n    match /supportMessages/{msgId} {\r\n      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;\r\n\r\n      allow get: if isAuthenticated() && (isStaff() || resource.data.clientId == request.auth.uid);\r\n\r\n      allow list: if isStaff()\r\n        || (isAuthenticated()\r\n            && request.query.limit != null\r\n            && request.query.limit <= 50);\r\n\r\n      allow update: if isStaff();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Chat interne staff\r\n    // ────────────────────────────────────────────────\r\n    match /staffMessages/{msgId} {\r\n      allow read, write: if isStaff();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Messages de contact (public)\r\n    // ────────────────────────────────────────────────\r\n    match /contactMessages/{msgId} {\r\n      allow create: if true;\r\n      allow read, update: if isStaff();\r\n      allow delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Mail (extension Firebase Email)\r\n    // ────────────────────────────────────────────────\r\n    match /mail/{mailId} {\r\n      allow create: if true;\r\n      allow read, update, delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Newsletter\r\n    // ────────────────────────────────────────────────\r\n    match /newsletter/{id} {\r\n      allow create: if true;\r\n      allow read, update, delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Avis pharmacie\r\n    // ────────────────────────────────────────────────\r\n    match /pharmacyReviews/{id} {\r\n      allow create: if isAuthenticated();\r\n      allow read: if true;\r\n      allow update, delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Sessions collaborateurs\r\n    // ────────────────────────────────────────────────\r\n    match /collaboratorSessions/{id} {\r\n      allow create, read, update, delete: if isAdmin();\r\n    }\r\n\r\n    // ────────────────────────────────────────────────\r\n    // Catch-all sécurité maximale\r\n    // ────────────────────────────────────────────────\r\n    match /{document=**} {\r\n      allow read, write: if false;\r\n    }\r\n  }\r\n}"}]}}
